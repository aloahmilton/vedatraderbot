# ══════════════════════════════════════════════════════
#  VEDA TRADER — Environment Variables
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:your_bot_token_here
FREE_TELEGRAM_CHANNEL_ID=-1001234567890
PUBLIC_CHANNEL_URL=https://t.me/vedatradersignals
PREMIUM_TELEGRAM_CHANNEL_ID=-1009876543210
PREMIUM_CHANNEL_ID=-1009876543210

# ── MongoDB ───────────────────────────────────────────
# FIX "No replica set members found" ERROR:
#   1. MongoDB Atlas → Security → Network Access
#   2. Click "Add IP Address" → "Allow Access from Anywhere" (0.0.0.0/0)
#   3. Save and wait 30 seconds, then restart the bot
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ── Web App ───────────────────────────────────────────
SECRET_KEY=replace_with_long_random_secret_at_least_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_USER_IDS=123456789,987654321

# ── Affiliate ─────────────────────────────────────────
AFFILIATE_LINK=https://example.com/affiliate
