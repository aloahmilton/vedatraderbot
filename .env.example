# ─────────────────────────────────────────
#  VEDA TRADER — Environment Variables
#  Rename this file to: .env
# ─────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
FREE_TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
PREMIUM_TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_CHAT_ID=your_personal_telegram_id   # Get this from @userinfobot on Telegram

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=YourApp

# Flask
SECRET_KEY=change-this-to-a-random-secret
PORT=5000

# Admin Panel Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword2026!

# Broker Affiliate Link (shown in broker reminder messages)
AFFILIATE_LINK=https://your-broker-affiliate-link.com

# AI Assistant (Claude API key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
