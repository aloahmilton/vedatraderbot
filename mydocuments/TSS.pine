//@version=5
indicator("Tri Session Sentinel — Veda Trader", shorttitle="TSS · Veda", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════
//  TRI SESSION SENTINEL v2 — Veda Trader
//
//  KEY FIXES vs v1:
//  ✅  Pre-signal warning (2 bars before crossover) so you
//      can enter early — not after the move has passed
//  ✅  Lines drawn only once (barstate.islast guard) — no
//      more duplicate lines or 500-line limit spam
//  ✅  lookahead_off on all security() calls — no repainting
//  ✅  Session overlap (London+NY 12-16 UTC) shown properly
//  ✅  Simplified UI — breathing room, less clutter
//  ✅  Clean compact dashboard — only what matters
// ══════════════════════════════════════════════════════════


// ─────────────────────────────────────────
//  GROUPS
// ─────────────────────────────────────────
g1 = "📅 Key Levels"
g2 = "🌍 Sessions"
g3 = "⚡ Signal Settings"
g4 = "🎨 Visuals"


// ─────────────────────────────────────────
//  INPUTS
// ─────────────────────────────────────────

// Key levels
show_pdh  = input.bool(true,  "Prev Day High / Low / Close", group=g1)
show_pwhl = input.bool(true,  "Prev Week High / Low",        group=g1)
pdh_col   = input.color(color.new(#00D4FF, 0),  "PDH",  group=g1, inline="pd")
pdl_col   = input.color(color.new(#FF4D6D, 0),  "PDL",  group=g1, inline="pd")
pdc_col   = input.color(color.new(#FFB800, 0),  "PDC",  group=g1, inline="pd")
pwh_col   = input.color(color.new(#00FF9D, 20), "PWH",  group=g1, inline="pw")
pwl_col   = input.color(color.new(#FF4D6D, 20), "PWL",  group=g1, inline="pw")

// Sessions
show_sess      = input.bool(true,  "Session Backgrounds",   group=g2)
show_sess_open = input.bool(true,  "Session Open Lines",    group=g2)
asia_col       = input.color(color.new(#9B59B6, 92), "Asia",   group=g2, inline="sc")
london_col     = input.color(color.new(#3498DB, 92), "London", group=g2, inline="sc")
ny_col         = input.color(color.new(#E67E22, 92), "NY",     group=g2, inline="sc")

// Signals
show_signals  = input.bool(true,  "Show Signals",      group=g3)
show_presig   = input.bool(true,  "Show Pre-Signals ⚡ (warning before crossover)", group=g3)
ema_fast_len  = input.int(9,      "EMA Fast",   minval=1, group=g3)
ema_slow_len  = input.int(21,     "EMA Slow",   minval=1, group=g3)
rsi_len       = input.int(14,     "RSI Period", minval=1, group=g3)
rsi_buy_min   = input.int(38,     "RSI Buy Min",  minval=1, maxval=100, group=g3)
rsi_buy_max   = input.int(68,     "RSI Buy Max",  minval=1, maxval=100, group=g3)
rsi_sel_min   = input.int(32,     "RSI Sell Min", minval=1, maxval=100, group=g3)
rsi_sel_max   = input.int(65,     "RSI Sell Max", minval=1, maxval=100, group=g3)
vol_mult      = input.float(0.8,  "Min Volume (x avg)", step=0.1, minval=0.1, group=g3)
stop_pct_inp  = input.float(0.3,  "Stop Loss %", step=0.05, minval=0.05, group=g3)
rr_inp        = input.float(2.0,  "Risk:Reward", step=0.5,  minval=0.5,  group=g3)

// Visuals
show_ema      = input.bool(true,  "Show EMA Lines", group=g4)
show_dash     = input.bool(true,  "Show Dashboard", group=g4)


// ─────────────────────────────────────────
//  INDICATORS
// ─────────────────────────────────────────
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
rsi_val  = ta.rsi(close, rsi_len)
vol_avg  = ta.sma(volume, 20)
high_vol = volume >= vol_avg * vol_mult

plot(show_ema ? ema_fast : na, "EMA Fast", color=color.new(#00D4FF, 0), linewidth=2)
plot(show_ema ? ema_slow : na, "EMA Slow", color=color.new(#FFB800, 0), linewidth=2)


// ─────────────────────────────────────────
//  PREVIOUS DAY H/L/C  — lookahead_off, no repaint
// ─────────────────────────────────────────
pd_high  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
pd_low   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
pd_close = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
pw_high  = request.security(syminfo.tickerid, "W", high[1],  lookahead=barmerge.lookahead_off)
pw_low   = request.security(syminfo.tickerid, "W", low[1],   lookahead=barmerge.lookahead_off)

// Draw lines ONLY on the last bar to avoid duplicates hitting the 500 limit
// Using var so the line objects persist and get extended
var line line_pdh = na
var line line_pdl = na
var line line_pdc = na
var line line_pwh = na
var line line_pwl = na

if barstate.islast
    if show_pdh
        line.delete(line_pdh)
        line_pdh := line.new(bar_index - 300, pd_high, bar_index, pd_high, extend=extend.right, color=pdh_col, width=1, style=line.style_dashed)

        line.delete(line_pdl)
        line_pdl := line.new(bar_index - 300, pd_low,  bar_index, pd_low,  extend=extend.right, color=pdl_col, width=1, style=line.style_dashed)

        line.delete(line_pdc)
        line_pdc := line.new(bar_index - 300, pd_close,bar_index, pd_close,extend=extend.right, color=pdc_col,  width=1, style=line.style_dotted)

    if show_pwhl
        line.delete(line_pwh)
        line_pwh := line.new(bar_index - 300, pw_high, bar_index, pw_high, extend=extend.right, color=pwh_col, width=2, style=line.style_solid)

        line.delete(line_pwl)
        line_pwl := line.new(bar_index - 300, pw_low,  bar_index, pw_low,  extend=extend.right, color=pwl_col, width=2, style=line.style_solid)

// Level labels — once per day / week only
is_new_day  = ta.change(time("D")) != 0
is_new_week = ta.change(time("W")) != 0

if is_new_day and show_pdh
    label.new(bar_index, pd_high, "PDH " + str.tostring(pd_high, format.mintick), color=color.new(pdh_col, 85), textcolor=pdh_col, style=label.style_label_left, size=size.tiny)
    label.new(bar_index, pd_low,  "PDL " + str.tostring(pd_low,  format.mintick), color=color.new(pdl_col, 85), textcolor=pdl_col, style=label.style_label_left, size=size.tiny)
    label.new(bar_index, pd_close,"PDC " + str.tostring(pd_close,format.mintick), color=color.new(pdc_col, 85), textcolor=pdc_col, style=label.style_label_left, size=size.tiny)

if is_new_week and show_pwhl
    label.new(bar_index, pw_high, "PWH " + str.tostring(pw_high, format.mintick), color=color.new(pwh_col, 80), textcolor=pwh_col, style=label.style_label_left, size=size.tiny)
    label.new(bar_index, pw_low,  "PWL " + str.tostring(pw_low,  format.mintick), color=color.new(pwl_col, 80), textcolor=pwl_col, style=label.style_label_left, size=size.tiny)


// ─────────────────────────────────────────
//  SESSIONS
// ─────────────────────────────────────────
in_asia    = not na(time(timeframe.period, "0000-0900:1234567", "UTC"))
in_london  = not na(time(timeframe.period, "0700-1600:1234567", "UTC"))
in_ny      = not na(time(timeframe.period, "1200-2100:1234567", "UTC"))
in_overlap = in_london and in_ny  // 12:00–16:00 UTC

asia_open   = in_asia   and not in_asia[1]
london_open = in_london and not in_london[1]
ny_open     = in_ny     and not in_ny[1]

// Backgrounds: overlap gets a blended orange-blue tint via NY color
// Asia only where London hasn't started, London only where NY hasn't, etc.
bgcolor(show_sess and in_asia    and not in_london ? color.new(asia_col,   96) : na, title="Asia Bg")
bgcolor(show_sess and in_london  and not in_ny     ? color.new(london_col, 96) : na, title="London Bg")
bgcolor(show_sess and in_overlap                   ? color.new(#FF9500,    96) : na, title="Overlap Bg")
bgcolor(show_sess and in_ny      and not in_london ? color.new(ny_col,     96) : na, title="NY Bg")

// Session open price lines — stored as var, only created once per session
var line line_asia_open   = na
var line line_london_open = na
var line line_ny_open     = na

if show_sess_open and asia_open
    line.delete(line_asia_open)
    line_asia_open := line.new(bar_index, open, bar_index + 1, open, extend=extend.right, color=color.new(#9B59B6, 20), width=1, style=line.style_solid)
    label.new(bar_index, open, "🌏 ASIA  " + str.tostring(open, format.mintick), color=color.new(#9B59B6, 80), textcolor=#9B59B6, style=label.style_label_right, size=size.tiny)

if show_sess_open and london_open
    line.delete(line_london_open)
    line_london_open := line.new(bar_index, open, bar_index + 1, open, extend=extend.right, color=color.new(#3498DB, 20), width=1, style=line.style_solid)
    label.new(bar_index, open, "🇬🇧 LONDON  " + str.tostring(open, format.mintick), color=color.new(#3498DB, 80), textcolor=#3498DB, style=label.style_label_right, size=size.tiny)

if show_sess_open and ny_open
    line.delete(line_ny_open)
    line_ny_open := line.new(bar_index, open, bar_index + 1, open, extend=extend.right, color=color.new(#E67E22, 20), width=1, style=line.style_solid)
    label.new(bar_index, open, "🗽 NEW YORK  " + str.tostring(open, format.mintick), color=color.new(#E67E22, 80), textcolor=#E67E22, style=label.style_label_right, size=size.tiny)


// ─────────────────────────────────────────
//  SIGNAL LOGIC
// ─────────────────────────────────────────
bull_cross = ta.crossover(ema_fast,  ema_slow)
bear_cross = ta.crossunder(ema_fast, ema_slow)

buy_signal  = show_signals and bull_cross and rsi_val >= rsi_buy_min and rsi_val <= rsi_buy_max and high_vol
sell_signal = show_signals and bear_cross and rsi_val >= rsi_sel_min and rsi_val <= rsi_sel_max and high_vol

stop_pct = stop_pct_inp / 100


// ─────────────────────────────────────────
//  PRE-SIGNAL WARNING
//  Fires 1-2 bars BEFORE the crossover so
//  traders can prepare their entry in advance
//
//  Logic: EMAs are converging AND gap is very
//  tight (< 0.04% of price) — cross is imminent
// ─────────────────────────────────────────
ema_gap       = ema_fast - ema_slow
ema_gap_prev  = ema_fast[1] - ema_slow[1]
ema_gap_pct   = math.abs(ema_gap) / ema_slow * 100
converging    = math.abs(ema_gap) < math.abs(ema_gap_prev)  // gap is shrinking

// Pre-BUY: fast EMA below slow but rising toward it, gap < 0.04%, RSI in zone
pre_buy  = show_presig and (ema_gap < 0) and converging and ema_gap_pct < 0.04
           and rsi_val >= rsi_buy_min and rsi_val <= rsi_buy_max
           and not bull_cross and not bull_cross[1]  // don't show if cross already fired

// Pre-SELL: fast EMA above slow but falling toward it, gap < 0.04%, RSI in zone
pre_sell = show_presig and (ema_gap > 0) and converging and ema_gap_pct < 0.04
           and rsi_val >= rsi_sel_min and rsi_val <= rsi_sel_max
           and not bear_cross and not bear_cross[1]


// ─────────────────────────────────────────
//  PLOT SIGNALS
// ─────────────────────────────────────────

// ── Pre-signal dots (subtle warning)
plotshape(pre_buy,  title="Pre-BUY",  style=shape.circle, location=location.belowbar, color=color.new(#00FF9D, 40), size=size.tiny,  text="")
plotshape(pre_sell, title="Pre-SELL", style=shape.circle, location=location.abovebar, color=color.new(#FF4D6D, 40), size=size.tiny,  text="")

// ── Confirmed signal arrows (clean, no text clutter on chart)
plotshape(buy_signal,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=#00FF9D, size=size.normal)
plotshape(sell_signal, title="SELL", style=shape.triangledown,  location=location.abovebar, color=#FF4D6D, size=size.normal)

// ── Signal detail label — entry, SL, TP
if buy_signal
    entry_p = close
    sl_p    = entry_p * (1 - stop_pct)
    tp_p    = entry_p * (1 + stop_pct * rr_inp)
    label.new(bar_index, low * (1 - stop_pct_inp * 0.003),
        "▲ BUY\n" +
        "E  " + str.tostring(entry_p, format.mintick) + "\n" +
        "SL " + str.tostring(sl_p,    format.mintick) + "\n" +
        "TP " + str.tostring(tp_p,    format.mintick),
        color=color.new(#00FF9D, 15),
        textcolor=color.new(#001A0D, 0),
        style=label.style_label_up,
        size=size.small)

if sell_signal
    entry_p = close
    sl_p    = entry_p * (1 + stop_pct)
    tp_p    = entry_p * (1 - stop_pct * rr_inp)
    label.new(bar_index, high * (1 + stop_pct_inp * 0.003),
        "▼ SELL\n" +
        "E  " + str.tostring(entry_p, format.mintick) + "\n" +
        "SL " + str.tostring(sl_p,    format.mintick) + "\n" +
        "TP " + str.tostring(tp_p,    format.mintick),
        color=color.new(#FF4D6D, 15),
        textcolor=color.white,
        style=label.style_label_down,
        size=size.small)

// Pre-signal label — minimal, just a nudge
if pre_buy  and not pre_buy[1]   // only on the first bar it appears
    label.new(bar_index, low, "⚡ GET READY", color=color.new(#00FF9D, 70), textcolor=#00FF9D, style=label.style_label_up, size=size.tiny)

if pre_sell and not pre_sell[1]
    label.new(bar_index, high, "⚡ GET READY", color=color.new(#FF4D6D, 70), textcolor=#FF4D6D, style=label.style_label_down, size=size.tiny)


// ─────────────────────────────────────────
//  DASHBOARD — compact, clean
//  Only the 5 things a scalper needs at a glance
// ─────────────────────────────────────────
var table dash = table.new(
    position.top_right, 2, 7,
    bgcolor       = color.new(#080D1A, 5),
    border_color  = color.new(#1E2D4A, 0),
    border_width  = 1,
    frame_color   = color.new(#00D4FF, 50),
    frame_width   = 1)

if show_dash
    bg0  = color.new(#0F1E35, 10)
    bg1  = color.new(#080D1A, 10)
    dimw = color.new(#8899AA, 0)
    wht  = color.new(#FFFFFF, 0)

    // Header
    table.cell(dash, 0, 0, "TSS · VEDA", text_color=#00D4FF,  bgcolor=bg0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, syminfo.ticker, text_color=#FFB800, bgcolor=bg0, text_size=size.small, text_halign=text.align_right)

    // Session
    sess_str = in_overlap ? "🔥 OVERLAP" : in_ny ? "🗽 NEW YORK" : in_london ? "🇬🇧 LONDON" : in_asia ? "🌏 ASIA" : "⏸ CLOSED"
    table.cell(dash, 0, 1, "Session",  text_color=dimw, bgcolor=bg1, text_size=size.tiny)
    table.cell(dash, 1, 1, sess_str,   text_color=wht,  bgcolor=bg1, text_size=size.tiny)

    // Signal status
    sig_str = buy_signal ? "▲ BUY" : sell_signal ? "▼ SELL" : pre_buy ? "⚡ BUY SOON" : pre_sell ? "⚡ SELL SOON" : "— waiting"
    sig_col = buy_signal ? #00FF9D : sell_signal ? #FF4D6D : (pre_buy or pre_sell) ? #FFB800 : color.new(#FFFFFF, 60)
    sig_bg  = buy_signal ? color.new(#00FF9D, 80) : sell_signal ? color.new(#FF4D6D, 80) : (pre_buy or pre_sell) ? color.new(#FFB800, 85) : bg1
    table.cell(dash, 0, 2, "Signal",   text_color=dimw,    bgcolor=sig_bg, text_size=size.tiny)
    table.cell(dash, 1, 2, sig_str,    text_color=sig_col, bgcolor=sig_bg, text_size=size.tiny)

    // RSI
    rsi_col = rsi_val > 70 ? #FF4D6D : rsi_val < 30 ? #00FF9D : wht
    table.cell(dash, 0, 3, "RSI",       text_color=dimw,    bgcolor=bg1, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(math.round(rsi_val * 10) / 10), text_color=rsi_col, bgcolor=bg1, text_size=size.tiny)

    // EMA state
    ema_str = bull_cross ? "▲ CROSSED UP" : bear_cross ? "▼ CROSSED DN" : ema_fast > ema_slow ? "↗ Fast above" : "↘ Fast below"
    ema_col = ema_fast > ema_slow ? #00D4FF : #FF4D6D
    table.cell(dash, 0, 4, "EMA 9/21",  text_color=dimw,    bgcolor=bg1, text_size=size.tiny)
    table.cell(dash, 1, 4, ema_str,     text_color=ema_col, bgcolor=bg1, text_size=size.tiny)

    // Volume
    vol_col = high_vol ? #00FF9D : #FFB800
    vol_str = high_vol ? "✔ OK" : "✖ LOW"
    table.cell(dash, 0, 5, "Volume",    text_color=dimw,    bgcolor=bg1, text_size=size.tiny)
    table.cell(dash, 1, 5, vol_str,     text_color=vol_col, bgcolor=bg1, text_size=size.tiny)

    // EMA gap (how close to crossover — useful for pre-signal)
    gap_str = str.tostring(math.round(ema_gap_pct * 1000) / 1000) + "%  " + (converging ? "↔ converging" : "↔ diverging")
    gap_col = ema_gap_pct < 0.02 ? #FFB800 : color.new(#FFFFFF, 50)
    table.cell(dash, 0, 6, "EMA Gap",   text_color=dimw,    bgcolor=bg1, text_size=size.tiny)
    table.cell(dash, 1, 6, gap_str,     text_color=gap_col, bgcolor=bg1, text_size=size.tiny)


// ─────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────
alertcondition(pre_buy  and not pre_buy[1],   title="⚡ Pre-BUY Warning",   message="VEDA TRADER ⚡ BUY SIGNAL APPROACHING on {{ticker}} @ {{close}} — EMAs converging. GET READY.")
alertcondition(pre_sell and not pre_sell[1],  title="⚡ Pre-SELL Warning",  message="VEDA TRADER ⚡ SELL SIGNAL APPROACHING on {{ticker}} @ {{close}} — EMAs converging. GET READY.")
alertcondition(buy_signal,                    title="▲ BUY Confirmed",      message="VEDA TRADER ✅ BUY CONFIRMED {{ticker}} @ {{close}} | RSI: {{plot_2}} | Set SL & TP now.")
alertcondition(sell_signal,                   title="▼ SELL Confirmed",     message="VEDA TRADER 🔴 SELL CONFIRMED {{ticker}} @ {{close}} | RSI: {{plot_2}} | Set SL & TP now.")
alertcondition(london_open,                   title="🇬🇧 London Open",       message="VEDA TRADER — London session open. Watch EUR/GBP pairs.")
alertcondition(ny_open,                       title="🗽 New York Open",      message="VEDA TRADER — New York session open. Watch USD pairs.")
alertcondition(asia_open,                     title="🌏 Asia Open",          message="VEDA TRADER — Asia session open. Watch JPY/AUD crosses.")
